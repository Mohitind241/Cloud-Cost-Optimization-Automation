# S3 backend runtime configuration
# Injected via: terraform init -backend-config="tfstate.config"
# ⚠ Never commit real bucket names / account IDs to a public repo —
#   replace the values below with your own.
bucket         = "cloud-cost-opt-tfstate-037049058665"
key            = "terraform/prod/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "cloud-cost-opt-tf-lock"
encrypt        = true
